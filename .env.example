# Claw-Compactor Integration Configuration
# Copy this file to .env and adjust values as needed

# Default workspace path for claw-compactor operations
# If not set, defaults to current directory (.)
# The workspace should contain a memory/ directory or MEMORY.md file
# Example: /path/to/project/workspace
CLAW_WORKSPACE=.

# Optional: Add claw-compactor lib directory to Python path
# This allows direct imports like: from claw_compactor.lib import observer
# Example: /path/to/project/skills/claw-compactor/lib
# PYTHONPATH=/path/to/project/skills/claw-compactor/lib
