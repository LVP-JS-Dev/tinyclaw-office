# ==============================================================================
# TinyClaw Office - Environment Configuration Template
# ==============================================================================
# Copy this file to .env and fill in the actual values for your environment.
#
# Required variables are marked with [REQUIRED]
# Optional variables are marked with [OPTIONAL]
# ==============================================================================

# ------------------------------------------------------------------------------
# OpenAI API (Required by MemU for embeddings)
# ------------------------------------------------------------------------------
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# ------------------------------------------------------------------------------
# Database Configuration (PostgreSQL for MemU)
# ------------------------------------------------------------------------------
# For production: Use PostgreSQL with pgvector extension
# For development: Can use in-memory mode (set MEMU_MODE=inmemory)

# Database credentials (used by docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_generate_secure_password
POSTGRES_DB=memu

# Full database URL (for direct connections)
# Use environment variables above to avoid hardcoding passwords
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}

# MemU storage mode: "inmemory" for development, "postgres" for production
MEMU_MODE=inmemory

# ------------------------------------------------------------------------------
# TinyClaw Configuration
# ------------------------------------------------------------------------------
# TinyClaw API endpoint (default: http://localhost:3777)
TINYCLAW_API_URL=http://localhost:3777

# Path to TinyClaw settings file (optional, defaults to ~/.tinyclaw/settings.json)
# TINYCLAW_SETTINGS_PATH=~/.tinyclaw/settings.json

# ------------------------------------------------------------------------------
# Gondolin Configuration
# ------------------------------------------------------------------------------
# Gondolin API endpoint (default: http://localhost:9000)
GONDOLIN_API_URL=http://localhost:9000

# Comma-separated list of allowed hosts for Gondolin HTTP hooks
# Only these hosts can be accessed from sandboxed code execution
GONDOLIN_ALLOWED_HOSTS=api.github.com,api.openai.com,api.anthropic.com

# ------------------------------------------------------------------------------
# Orchestration API Configuration
# ------------------------------------------------------------------------------
# Main orchestration API port (default: 8080)
API_PORT=8080

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
LOG_LEVEL=INFO

# Secret key for API authentication [REQUIRED]
# Generate a secure random string: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# ------------------------------------------------------------------------------
# Optional: External Service Credentials
# ------------------------------------------------------------------------------
# GitHub token for Gondolin sandboxed code execution (optional)
# Get from: https://github.com/settings/tokens
# GITHUB_TOKEN=ghp_your-github-token-here

# Anthropic API key for Claude integration (optional)
# Get from: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# ------------------------------------------------------------------------------
# Optional: Redis Configuration (for caching)
# ------------------------------------------------------------------------------
# Redis URL for caching layer (optional)
# REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------------------------
# Optional: Dashboard Configuration
# ------------------------------------------------------------------------------
# Dashboard frontend port (default: 3001, avoid conflict with TinyClaw portal on 3000)
# DASHBOARD_PORT=3001

# ------------------------------------------------------------------------------
# Optional: Development/Debug Settings
# ------------------------------------------------------------------------------
# Enable debug mode (shows detailed error messages, disables some security)
# DEBUG=false

# Enable CORS for all origins (only for development)
# CORS_ORIGINS=http://localhost:3001,http://localhost:8080
